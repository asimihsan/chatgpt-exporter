{
  "name": "@pionxzh/chatgpt-exporter",
  "type": "module",
  "version": "2.29.3",
  "private": true,
  "packageManager": "bun@1.3.8",
  "title": "ChatGPT Exporter",
  "title:zh-CN": "ChatGPT Exporter",
  "title:zh-TW": "ChatGPT Exporter",
  "description": "Easily export the whole ChatGPT conversation history for further analysis or sharing.",
  "description:zh-CN": "轻松导出 ChatGPT 聊天记录，以便进一步分析或分享。",
  "description:zh-TW": "輕鬆匯出 ChatGPT 聊天紀錄，以便進一步分析或分享。",
  "author": "pionxzh",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test": "npm run typecheck && npm run test:unit",
    "check": "npm run lint && npm run test",
    "deps:update": "bun update --latest",
    "deps:check": "bun outdated",
    "lint": "eslint . --config eslint.type-aware.config.js --max-warnings=0",
    "lint:type-aware": "eslint . --config eslint.type-aware.config.js --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.14",
    "@radix-ui/react-dialog": "^1.0.3",
    "@radix-ui/react-hover-card": "^1.0.5",
    "hast-util-to-html": "^9.0.5",
    "html2canvas": "^1.4.1",
    "i18next": "^22.5.1",
    "jszip": "3.10.1",
    "mdast": "^3.0.0",
    "mdast-util-from-markdown": "^2.0.2",
    "mdast-util-frontmatter": "^2.0.1",
    "mdast-util-gfm": "^3.1.0",
    "mdast-util-to-hast": "^13.2.1",
    "mdast-util-to-markdown": "^2.1.2",
    "micromark-extension-gfm": "^3.0.0",
    "mitt": "^3.0.1",
    "preact": "^10.28.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^12.3.1",
    "sanitize-filename": "^1.6.3",
    "sentinel-js": "^0.0.7",
    "urlcat": "^3.1.0",
    "vite-plugin-monkey": "^7.1.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@preact/preset-vite": "^2.10.3",
    "@types/katex": "^0.16.8",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.2.2",
    "@types/unist": "^3.0.3",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.0",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "katex": "^0.16.28",
    "lint-staged": "^16.2.7",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "bunx eslint"
  }
}
