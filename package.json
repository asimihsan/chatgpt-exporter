    "preact": "^10.29.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.7",
    "sanitize-filename": "^1.6.4",
    "sentinel-js": "^0.0.7",
    "vite-plugin-monkey": "^8.0.2"
