  "devDependencies": {
    "@commitlint/config-conventional": "^21.0.0",
    "@commitlint/lint": "^21.0.0",
    "@eslint/js": "^10.0.1",
    "@preact/preset-vite": "^2.10.5",
    "@types/jsdom": "^28.0.1",
    "@types/katex": "^0.16.8",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.6.2",
    "@types/unist": "^3.0.3",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
