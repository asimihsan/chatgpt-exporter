    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-regexp": "^3.1.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "katex": "^0.16.45",
    "rollup": "^4.60.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
