  "description": "Easily export the whole ChatGPT conversation history for further analysis or sharing.",
  "description:zh-CN": "轻松导出 ChatGPT 聊天记录，以便进一步分析或分享。",
  "description:zh-TW": "輕鬆匯出 ChatGPT 聊天紀錄，以便進一步分析或分享。",
  "author": "asimihsan",
  "homepage": "https://github.com/asimihsan/chatgpt-exporter",
  "repository": {
    "type": "git",
    "url": "https://github.com/asimihsan/chatgpt-exporter.git"
  },
  "bugs": {
    "url": "https://github.com/asimihsan/chatgpt-exporter/issues"
  },
  "license": "MPL-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "brace-expansion": "5.0.5",
    "flatted": "3.4.2",
    "minimatch": "10.2.4",
    "picomatch": "4.0.4",
    "rollup": "4.60.3",
    "undici": "7.24.0",
    "yaml": "2.8.3"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test": "npm run typecheck && npm run test:unit",
    "check": "npm run lint && npm run test",
    "deps:update": "bun update --latest",
    "deps:check": "bun outdated",
    "lint": "eslint . --config eslint.type-aware.config.js --max-warnings=0",
    "lint:type-aware": "eslint . --config eslint.type-aware.config.js --max-warnings=0",
    "lint:fix": "eslint . --fix"
